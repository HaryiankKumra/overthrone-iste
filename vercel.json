{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm --filter @workspace/overthrone run build",
  "outputDirectory": "artifacts/overthrone/dist/public",
  "functions": {
    "api/[...all].ts": {
      "runtime": "nodejs20.x",
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/[...all].ts"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
