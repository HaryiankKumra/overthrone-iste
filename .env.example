# Supabase project identity
SUPABASE_PROJECT_REF=
SUPABASE_URL=
SUPABASE_SECRET_KEY=
SUPABASE_PUBLISHABLE_KEY=

# Compatibility for Next.js-style client env names
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Vite client env names used by this repository
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Core database connection
# Direct DB example:
# postgresql://postgres:<db-password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require
DATABASE_URL=

# Enable SSL for managed databases (Supabase, Neon, RDS, etc.)
DATABASE_SSL=true

# Pool tuning for serverless traffic
PG_POOL_MAX=10
PG_IDLE_TIMEOUT_MS=10000
PG_CONNECT_TIMEOUT_MS=5000

# Session signing secret for auth tokens
SESSION_SECRET=change-me-in-production

# Comma-separated allowlist for browser origins hitting API
# Example: https://overthrone.vercel.app,https://admin.overthrone.vercel.app
CORS_ORIGINS=

# Frontend and local app runtime values
BASE_PATH=/
PORT=5173

# Vercel/serverless deploy: keep false to avoid ws reconnect noise.
# Local fullstack dev (single long-running api process): set true if desired.
VITE_ENABLE_WEBSOCKET=false

# Shared bearer secret for invoking your Supabase Edge function from trusted services
EDGE_SHARED_SECRET=change-me-for-edge-calls
