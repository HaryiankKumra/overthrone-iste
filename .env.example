# Core database connection (Supabase transaction pooler recommended for production)
# Example format:
# postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=

# Enable SSL for managed databases (Supabase, Neon, RDS, etc.)
DATABASE_SSL=true

# Pool tuning for serverless traffic
PG_POOL_MAX=10
PG_IDLE_TIMEOUT_MS=10000
PG_CONNECT_TIMEOUT_MS=5000

# Session signing secret for auth tokens
SESSION_SECRET=change-me-in-production

# Comma-separated allowlist for browser origins hitting API
# Example: https://overthrone.vercel.app,https://admin.overthrone.vercel.app
CORS_ORIGINS=

# Frontend Vite values
BASE_PATH=/
PORT=5173

# Vercel/serverless deploy: keep false to avoid ws reconnect noise.
# Local fullstack dev (single long-running api process): set true if desired.
VITE_ENABLE_WEBSOCKET=false

# Supabase public/client env aliases
VITE_SUPABASE_URL=https://esbmtfhloqjzktpvemjq.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
NEXT_PUBLIC_SUPABASE_URL=https://esbmtfhloqjzktpvemjq.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key

# Supabase project/edge runtime env
SUPABASE_URL=https://esbmtfhloqjzktpvemjq.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_PROJECT_REF=esbmtfhloqjzktpvemjq
EDGE_SHARED_SECRET=replace-with-a-long-random-secret
