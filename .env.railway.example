# Runtime
NODE_ENV=production
PORT=8080
BASE_PATH=/

# Frontend build-time variables
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key

# Keep polling by default because websocket fan-out is in-memory per instance.
# Set true only when running a single API instance.
VITE_ENABLE_WEBSOCKET=false

# API and auth
SESSION_SECRET=replace-with-a-long-random-secret
CORS_ORIGINS=https://your-railway-domain.up.railway.app

# Database
DATABASE_URL=postgresql://postgres:password@host:5432/postgres?sslmode=require
DATABASE_SSL=true
PG_POOL_MAX=10
PG_IDLE_TIMEOUT_MS=10000
PG_CONNECT_TIMEOUT_MS=5000

# Optional compatibility/env aliases
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
SUPABASE_SERVICE_ROLE_KEY=replace-when-needed
EDGE_SHARED_SECRET=replace-for-edge-calls

# Optional override if your build artifacts live in a custom location.
# FRONTEND_DIST_DIR=/app/artifacts/overthrone/dist/public
